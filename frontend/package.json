{
  "name": "@gradion/crm-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:storybook": "vitest run --project storybook"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@shared/token": "file:../vendor/forge/shared-token-0.2.0.tgz",
    "@shared/ui": "file:../vendor/forge/shared-ui-0.2.1.tgz",
    "@tanstack/react-query": "^5.100.9",
    "lucide-react": "^0.577.0",
    "openapi-fetch": "^0.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.0.0",
    "tslib": "^2.8.1",
    "typescript": "~5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
