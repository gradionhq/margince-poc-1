{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-push-gate.sh",
            "if": "Bash(git push*)",
            "statusMessage": "Running pre-push gate (gates + craft review)",
            "timeout": 300
          }
        ]
      }
    ]
  }
}
